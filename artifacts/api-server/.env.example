# API server configuration — copy to `.env` and fill in real values.
# `.env` is git-ignored; never commit real keys. See ARCHITECTURE.md §16.

# --- Database (Postgres) ---
DATABASE_URL=postgres://user:password@host:5432/dempo?sslmode=require

# --- Object storage (S3-compatible: DigitalOcean Spaces / AWS S3 / R2 / MinIO) ---
# Example endpoint for DO Spaces in Bangalore: https://blr1.digitaloceanspaces.com
STORAGE_ENDPOINT=https://blr1.digitaloceanspaces.com
STORAGE_REGION=blr1
STORAGE_BUCKET=dempo-uploads
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_FORCE_PATH_STYLE=false
# Key prefixes WITHIN the bucket (not full paths):
PRIVATE_OBJECT_DIR=private
PUBLIC_OBJECT_SEARCH_PATHS=public

# --- Auth (Clerk) ---
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# --- AI grading (Sarvam AI, OpenAI-compatible) — off until compliance sign-off ---
AI_GRADING_ENABLED=false
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.sarvam.ai/v1
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_GRADING_MODEL=sarvam-105b

# --- Notifications (MSG91) ---
MSG91_AUTH_KEY=
MSG91_EMAIL_DOMAIN=
MSG91_WHATSAPP_ENABLED=false
MSG91_SMS_ENABLED=false

# --- Observability (optional) ---
SENTRY_DSN=

NODE_ENV=development
