# aipraveen.com — environment template.
# With NONE of these set, the app runs fully in dev mode:
#   - in-memory data store (seeded demo learner + admin)
#   - magic-link login links printed to the server console
#   - mock Razorpay checkout (no real charge)
# Set these in production to switch to real services.

# --- Database (Supabase, Mumbai / ap-south-1) ---
# When set, use the Drizzle/Postgres path (run `pnpm db:push` to create tables).
DATABASE_URL=

# --- Razorpay (payments, INR) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Public key id exposed to the browser checkout widget.
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# --- MSG91 (transactional email, India) ---
MSG91_EMAIL_ENABLED=false
MSG91_AUTHKEY=
MSG91_FROM_EMAIL=hello@aipraveen.com
MSG91_EMAIL_DOMAIN=
MSG91_TEMPLATE_MAGIC_LINK=
MSG91_TEMPLATE_RECEIPT=

# --- Video (Cloudflare Stream — intended provider) ---
# Signed-playback keys for view-only HLS. Player uses a stub until set.
CLOUDFLARE_STREAM_ACCOUNT_ID=
CLOUDFLARE_STREAM_TOKEN=

# --- App ---
NEXT_PUBLIC_SITE_URL=https://aipraveen.com
